 "cells": [
  {
   "cell_type": "markdown",
   "id": "header",
   "metadata": {},
   "source": [
    "# Intelligent Electric Mobility (Iberdrola) — Datathon submission\n",
    "**Team: Zero Heroes** · *Architecture: GitHub Cloud Hub*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Environment & Global Configuration\n",
    "import os, sys, subprocess, requests\n",
    "from pathlib import Path\n",
    "\n",
    "BASE = Path('/content/datathon')\n",
    "BASE.mkdir(parents=True, exist_ok=True)\n",
    "os.chdir(BASE)\n",
    "\n",
    "# ── CONFIGURATION ───────────────────────────────────────────────────────────\n",
    "GITHUB_USER = \"lukatcheishvili\"\n",
    "GITHUB_REPO = \"Datathon-IE\"\n",
    "GITHUB_BRANCH = \"main\"\n",
    "GITHUB_RAW = f\"https://raw.githubusercontent.com/{GITHUB_USER}/{GITHUB_REPO}/{GITHUB_BRANCH}\"\n",
    "\n",
    "print(\"🚀 Initializing Zero Heroes Environment...\")\n",
    "pkgs = ['folium', 'geopandas', 'pyproj', 'polars', 'lxml', 'pdfplumber', 'plotly', 'pmdarima', 'streamlit-folium']\n",
    "subprocess.run([sys.executable, '-m', 'pip', 'install', '-q'] + pkgs)\n",
    "print(\"✅ Environment Ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sync",
   "metadata": {},
   "source": [
    "## 2. Global Asset Synchronization\n",
    "Programmatically pulling scripts and datasets from the GitHub Cloud repository."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "harvest",
   "metadata": {},
   "outputs": [],
   "source": [
    "tasks = [\n",
    "    (\"Datathon/generate_visualizations.py\", \"generate_visualizations.py\"),\n",
    "    (\"Datathon/dashboard.py\", \"dashboard.py\"),\n",
    "    (\"Datathon/generate_overview.py\", \"generate_overview.py\"),\n",
    "    (\"Datathon/data/Iberdrola%20Historical%20Map%20of%20Electricity%20Consumption%20Capacity/2026_03_05_R1-001_Demanda.csv\", \"data/iberdrola/demanda.csv\"),\n",
    "    (\"Datathon/data/VIESGO/2026_04_01_R1005_demanda_Consumption%20capacity%20in%20the%20network.csv\", \"data/viesgo/demanda.csv\")\n",
    "]\n",
    "\n",
    "for remote, local in tasks:\n",
    "    dest = BASE / local\n",
    "    dest.parent.mkdir(parents=True, exist_ok=True)\n",
    "    url = f\"{GITHUB_RAW}/{remote}\"\n",
    "    print(f\"  → Syncing: {local}\")\n",
    "    r = requests.get(url)\n",
    "    if r.status_code == 200: dest.write_bytes(r.content)\n",
    "\n",
    "print(\"✅ Subsystems Synced\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "engine",
   "metadata": {},
   "source": [
    "## 3. Zero Heroes Analytics Engine\n",
    "Running the 2027 demand simulations and generating visual outputs."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "run",
   "metadata": {},
   "outputs": [],
   "source": [
    "sys.path.append(str(BASE))\n",
    "try:\n",
    "    subprocess.run([sys.executable, 'generate_visualizations.py'])\n",
    "    print(\"✅ Success: Analytics suite executed. Outputs in /visualizations\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Run failed: {e}\")"
   ]
  }
 ],
